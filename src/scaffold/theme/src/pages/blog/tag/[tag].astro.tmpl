---
import Base from "../../../layouts/Base.astro";
import { publicPosts } from "../../../posts";
import { tags, termOf } from "../../../taxonomy";

export async function getStaticPaths() {
  const posts = await publicPosts();
  const reg = tags();
  const groups = new Map<string, typeof posts>();
  for (const p of posts) {
    for (const t of p.data.tags ?? []) {
      if (!groups.has(t)) groups.set(t, []);
      groups.get(t)!.push(p);
    }
  }
  return [...groups].map(([slug, items]) => ({
    params: { tag: slug },
    props: { term: termOf(reg, slug), posts: items },
  }));
}

const { term, posts } = Astro.props;
---

<Base title={`#${term.name} — articles`} description={term.description || `Articles tagged ${term.name}`}>
  <h1>#{term.name}</h1>
  {term.description && <p>{term.description}</p>}
  <ul class="post-list">
    {posts.map((p) => (
      <li>
        <a href={`/blog/${p.id}/`}>{p.data.title}</a>
        <p class="summary">{p.data.summary}</p>
      </li>
    ))}
  </ul>
  <p><a href="/">← All posts</a></p>
</Base>
