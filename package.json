{
  "name": "@vijayatech/glint",
  "version": "0.1.0",
  "description": "The lightning publishing engine for the AI era — git-native, static-output, agent-first, SEO/AEO-native.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "publishConfig": { "access": "public" },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "glint": "./dist/cli/index.js"
  },
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./schema": { "types": "./dist/content/schema.d.ts", "import": "./dist/content/schema.js" }
  },
  "files": ["dist", "src/scaffold"],
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "glint": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["astro", "static-site", "publishing", "aeo", "seo", "agent", "git-native"],
  "dependencies": {
    "turndown": "^7.2.4",
    "yaml": "^2.9.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/turndown": "^5.0.6",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
